LOCUS_ENV=development
LOCUS_DEBUG=true
LOCUS_HOST=0.0.0.0
LOCUS_PORT=8000
LOCUS_LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/locus
REDIS_URL=redis://localhost:6379/0

LOCUS_AUTH_MODE=dev
LOCUS_DEV_USER_ID=dev-user
LOCUS_DEV_USER_EMAIL=dev@locus.local

CRUSTDATA_API_KEY=
CRUSTDATA_API_BASE_URL=https://api.crustdata.com
CRUSTDATA_API_VERSION=2025-11-01

LOCUS_GEOCODER_PROVIDER=noop
LOCUS_GEOCODER_CACHE_TTL_SECONDS=86400
LOCUS_GEOCODER_TIMEOUT_SECONDS=10
LOCUS_GEOCODER_USER_AGENT="Locus/0.1 (dev@locus.local)"
